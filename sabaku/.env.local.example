# SABAKU env vars
# Copy this file to .env.local and fill in real values.

# ── Supabase (Auth + cloud sync) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe (Pro subscriptions) ──
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxx

# ── Gumroad (Lifetime license) ──
GUMROAD_PRODUCT_ID=your-gumroad-product-id

# ── Sentry (optional, error tracking) ──
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=sabaku

# ── App ──
NEXT_PUBLIC_APP_URL=https://sabaku.kyren.app

# ── Sync CLI (optional, for sabaku-sync.config.json local use) ──
# Uses NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY above
